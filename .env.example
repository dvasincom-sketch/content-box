# ==============================================================================
# Content Box — пример переменных окружения.
# Скопируйте в `.env` (`cp .env.example .env`) и подставьте свои значения.
# НИКОГДА не коммитьте реальный `.env` — он в .gitignore.
# ==============================================================================

# --- База данных (PostgreSQL, обязательно) --------------------------------
# Именно DATABASE_URL (с L), не DATABASE_URI.
DATABASE_URL=postgres://user:password@host:5432/contentbox

# --- Payload (обязательно) ------------------------------------------------
# Длинная случайная строка. Сгенерировать: `openssl rand -base64 32`.
# При смене секрета разлогинятся сессии и сломаются зашифрованные поля/токены.
PAYLOAD_SECRET=change-me-to-a-long-random-string

# --- Медиа: Cloudflare R2 (S3-совместимо, обязательно для загрузок) --------
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=your-bucket-name
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Публичный домен раздачи файлов. Нужен ДВАЖДЫ: как Build Argument для
# `next build` (иначе next/image не пропустит R2 в images.remotePatterns)
# И как рантайм-переменная.
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# --- Видео: Kinescope (обязательно для работы с видео) ---------------------
KINESCOPE_API_TOKEN=your-kinescope-api-token
KINESCOPE_PARENT_ID=your-kinescope-parent-folder-id

# --- Cloudflare Stream (опционально, legacy) -------------------------------
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# CF_STREAM_CUSTOMER_CODE=
# CF_STREAM_KEY_ID=
# CF_STREAM_SIGNING_KEY=
